/* Page Background */
body {
    font-family: Arial, sans-serif;
    background-color: #f4f6f9;
    margin: 0;
    padding: 0;
}

/* Main Container */
body > h2,
form,
hr {
    width: 500px;
    margin-left: auto;
    margin-right: auto;
}

/* Title */
h2 {
    text-align: center;
    color: #1e3a8a;
    margin-top: 30px;
}

/* Profile Card */
form {
    background-color: white;
    padding: 20px;
    margin-top: 15px;
    border-radius: 8px;
    box-shadow: 0px 4px 12px rgba(0,0,0,0.1);
}

/* Labels */
label {
    font-weight: bold;
    color: #333;
}

/* Inputs */
input[type="text"],
input[type="email"],
input[type="password"],
input[type="file"] {
    width: 100%;
    padding: 8px;
    margin-top: 5px;
    margin-bottom: 12px;
    border: 1px solid #ccc;
    border-radius: 5px;
}

/* Readonly field */
input[readonly] {
    background-color: #e5e7eb;
}

/* Buttons */
input[type="submit"] {
    background-color: #1e3a8a;
    color: white;
    border: none;
    padding: 10px;
    width: 100%;
    border-radius: 5px;
    cursor: pointer;
    font-weight: bold;
}

input[type="submit"]:hover {
    background-color: #2563eb;
}

/* Profile Image Section */
div[style*="float:right"] {
    position: absolute;
    right: 50px;
    top: 120px;
    width: 180px;
    text-align: center;
}

/* Image Box */
img {
    margin-top: 10px;
    border-radius: 50%;
    border: 2px solid #1e3a8a;
    object-fit: cover;
}

/* No Image Text */
p {
    color: #888;
}

/* Divider */
hr {
    margin-top: 30px;
    margin-bottom: 10px;
}

/* Section Title */
h3 {
    width: 500px;
    margin: 20px auto 10px auto;
    color: #1e3a8a;
}