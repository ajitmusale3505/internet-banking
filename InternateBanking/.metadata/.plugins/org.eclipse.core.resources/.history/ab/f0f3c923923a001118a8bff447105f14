/* ===== NAVBAR BASE ===== */
body {
    margin: 0;
    font-family: Arial, sans-serif;
}

/* ===== NAVBAR ===== */
.navbar {
    position: fixed;
    top: 0;
    width: 100%;
    background-color: #1e3a8a;
    color: white;
    display: flex;
    justify-content: space-between;
    align-items: center;

    padding: 12px 40px;
    box-sizing: border-box;
    z-index: 1000;
}

/* ===== LOGO ===== */
.logo {
    font-size: 20px;
    font-weight: bold;
}

/* ===== CENTER LINKS ===== */
.navbar-center {
    display: flex;
    gap: 25px;
}

.navbar-center a {
    color: white;
    text-decoration: none;
    font-weight: 500;
}

.navbar-center a:hover {
    text-decoration: underline;
}

/* ===== RIGHT SECTION ===== */
.navbar-right {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-right: 20px; /* 👈 spacing from right edge */
}

/* ===== PROFILE ICON ===== */
.profile-container {
    position: relative;
    cursor: pointer;
}

.profile-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid white;
}

/* Default avatar */
.default-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #2563eb;
    color: white;
    font-weight: bold;
}

/* ===== DROPDOWN ===== */
.dropdown {
    position: absolute;
    right: 0;
    top: 45px;
    background: white;
    min-width: 160px;
    border-radius: 8px;
    box-shadow: 0px 4px 12px rgba(0,0,0,0.15);
    display: none;
    padding: 10px;
    z-index: 1000;
}

.dropdown p {
    margin: 0 0 8px;
    font-size: 14px;
    color: #1e3a8a;
}

.dropdown a {
    display: block;
    text-decoration: none;
    color: #333;
    padding: 6px 0;
}

.dropdown a:hover {
    color: #1e3a8a;
}

/* ===== FIX DROPDOWN DISAPPEAR ISSUE ===== */
.profile-container:hover .dropdown,
.dropdown:hover {
    display: block;
}