/* ============================================================
   NexaBank — User Profile Stylesheet
   Theme: Luxury Dark Banking
   Fonts: Playfair Display (headings) + DM Sans (body)
   ============================================================ */

/* ── CSS Variables ─────────────────────────────────────────── */
:root {
    --bg-base:        #080d1a;
    --bg-surface:     #0e1628;
    --bg-card:        #111d35;
    --bg-input:       #0a1221;
    --bg-hover:       #162240;

    --gold:           #c9a84c;
    --gold-light:     #e2c97e;
    --gold-dim:       rgba(201, 168, 76, 0.15);
    --gold-border:    rgba(201, 168, 76, 0.3);

    --text-primary:   #e8eaf0;
    --text-secondary: #8a9bbf;
    --text-muted:     #4a5878;
    --text-gold:      #c9a84c;

    --border:         rgba(255, 255, 255, 0.07);
    --border-focus:   rgba(201, 168, 76, 0.6);

    --radius-sm:      6px;
    --radius-md:      12px;
    --radius-lg:      18px;
    --radius-xl:      24px;

    --shadow-card:    0 4px 40px rgba(0, 0, 0, 0.5);
    --shadow-glow:    0 0 30px rgba(201, 168, 76, 0.1);

    --transition:     0.22s ease;
    --font-display:   'Playfair Display', Georgia, serif;
    --font-body:      'DM Sans', sans-serif;
}

/* ── Reset & Base ───────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
    font-family: var(--font-body);
    background-color: var(--bg-base);
    color: var(--text-primary);
    font-size: 15px;
    line-height: 1.6;
    min-height: 100vh;
    background-image:
        radial-gradient(ellipse 80% 50% at 20% -10%, rgba(201,168,76,0.06) 0%, transparent 60%),
        radial-gradient(ellipse 60% 40% at 80% 110%, rgba(30,60,120,0.3) 0%, transparent 60%);
}

/* ── Top Navigation ─────────────────────────────────────────── */
.topnav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    height: 64px;
    background: rgba(8, 13, 26, 0.9);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
}

.topnav__brand {
    display: flex;
    align-items: center;
    gap: 10px;
}

.topnav__logo-icon {
    font-size: 18px;
    color: var(--gold);
    line-height: 1;
}

.topnav__logo-text {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: 0.5px;
}

.topnav__user {
    display: flex;
    align-items: center;
    gap: 20px;
}

.topnav__greeting {
    font-size: 13.5px;
    color: var(--text-secondary);
}

.topnav__greeting strong {
    color: var(--text-primary);
    font-weight: 600;
}

.topnav__logout {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 7px 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: var(--transition);
}

.topnav__logout:hover {
    color: var(--gold);
    border-color: var(--gold-border);
    background: var(--gold-dim);
}

/* ── Page Header ────────────────────────────────────────────── */
.page-header {
    padding: 52px 40px 32px;
    max-width: 1100px;
    margin: 0 auto;
}

.page-header__eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 8px;
}

.page-header__title {
    font-family: var(--font-display);
    font-size: 36px;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.2;
}

/* ── Main Content ───────────────────────────────────────────── */
.main-content {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px 80px;
    display: flex;
    flex-direction: column;
    gap: 28px;
}

/* ── Cards ──────────────────────────────────────────────────── */
.card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 36px 40px;
    box-shadow: var(--shadow-card);
    animation: fadeSlideUp 0.4s ease both;
}

.profile-card { animation-delay: 0.05s; }
.password-card { animation-delay: 0.15s; }

@keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
}

.card__header {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 32px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--border);
}

.card__header-icon {
    width: 44px;
    height: 44px;
    background: var(--gold-dim);
    border: 1px solid var(--gold-border);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    color: var(--gold);
    flex-shrink: 0;
}

.card__header-icon--gold {
    background: linear-gradient(135deg, rgba(201,168,76,0.25), rgba(201,168,76,0.1));
}

.card__title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
}

.card__subtitle {
    font-size: 13.5px;
    color: var(--text-secondary);
}

/* ── Profile Two-Column Layout ──────────────────────────────── */
.profile-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 48px;
    align-items: start;
}

.profile-form-col {
    display: flex;
    flex-direction: column;
}

/* ── Form Elements ──────────────────────────────────────────── */
.profile-form,
.password-form {
    display: flex;
    flex-direction: column;
    gap: 22px;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.form-label {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--text-secondary);
}

.input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.input-icon {
    position: absolute;
    left: 14px;
    font-size: 15px;
    color: var(--text-muted);
    pointer-events: none;
    z-index: 1;
}

.form-input {
    width: 100%;
    padding: 13px 16px 13px 42px;
    background: var(--bg-input);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 14.5px;
    transition: border-color var(--transition), box-shadow var(--transition), background var(--transition);
    outline: none;
}

.form-input::placeholder {
    color: var(--text-muted);
}

.form-input:focus {
    border-color: var(--border-focus);
    box-shadow: 0 0 0 3px rgba(201, 168, 76, 0.1);
    background: var(--bg-hover);
}

.form-input--readonly {
    color: var(--gold);
    font-weight: 600;
    cursor: not-allowed;
    background: rgba(201,168,76,0.05);
    border-color: var(--gold-border);
}

.form-hint {
    font-size: 12px;
    color: var(--text-muted);
    padding-left: 2px;
}

.toggle-password {
    position: absolute;
    right: 14px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 15px;
    color: var(--text-muted);
    opacity: 0.5;
    transition: opacity var(--transition);
    padding: 0;
    line-height: 1;
}

.toggle-password:hover { opacity: 1; }

/* ── Buttons ────────────────────────────────────────────────── */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 13px 28px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.3px;
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: all var(--transition);
    text-decoration: none;
}

.btn--primary {
    background: linear-gradient(135deg, #c9a84c, #a8872c);
    color: #0a0d14;
    box-shadow: 0 4px 18px rgba(201, 168, 76, 0.3);
    align-self: flex-start;
    margin-top: 6px;
}

.btn--primary:hover {
    background: linear-gradient(135deg, #e2c97e, #c9a84c);
    box-shadow: 0 6px 24px rgba(201, 168, 76, 0.45);
    transform: translateY(-1px);
}

.btn--primary:active { transform: translateY(0); }

.btn--secondary {
    background: transparent;
    color: var(--gold);
    border: 1px solid var(--gold-border);
    width: 100%;
}

.btn--secondary:hover {
    background: var(--gold-dim);
    border-color: var(--gold);
}

/* ── Profile Avatar Column ──────────────────────────────────── */
.profile-image-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
}

.avatar-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 28px 24px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    width: 100%;
}

.avatar-wrapper {
    position: relative;
    width: 110px;
    height: 110px;
    border-radius: 50%;
    cursor: pointer;
    overflow: hidden;
    border: 3px solid var(--gold-border);
    box-shadow: 0 0 0 6px rgba(201,168,76,0.07);
    transition: box-shadow var(--transition);
}

.avatar-wrapper:hover {
    box-shadow: 0 0 0 6px var(--gold-dim);
}

.avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.avatar-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a2a4a, #0f1c35);
    display: flex;
    align-items: center;
    justify-content: center;
}

.avatar-initials {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
}

.avatar-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #fff;
}

.avatar-wrapper:hover .avatar-overlay { opacity: 1; }

.avatar-name {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    color: var(--text-primary);
    text-align: center;
}

.avatar-email {
    font-size: 12.5px;
    color: var(--text-secondary);
    text-align: center;
}

/* ── File Upload ────────────────────────────────────────────── */
.upload-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.upload-label {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: var(--bg-input);
    border: 1px dashed rgba(201,168,76,0.35);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: var(--transition);
}

.upload-label:hover {
    border-color: var(--gold);
    background: var(--bg-hover);
}

.upload-icon {
    font-size: 18px;
    color: var(--gold);
}

.upload-text {
    font-size: 13px;
    color: var(--text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
}

.upload-input {
    display: none;
}

/* ── Password Section ───────────────────────────────────────── */
.password-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
}

.password-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding-top: 8px;
    flex-wrap: wrap;
}

.password-note {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-secondary);
    max-width: 420px;
}

.password-note__icon {
    font-size: 16px;
    color: var(--gold);
    flex-shrink: 0;
}

/* ── Footer ─────────────────────────────────────────────────── */
.site-footer {
    text-align: center;
    padding: 24px 40px;
    border-top: 1px solid var(--border);
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.3px;
}

/* ── Responsive ─────────────────────────────────────────────── */
@media (max-width: 900px) {
    .profile-layout {
        grid-template-columns: 1fr;
    }
    .profile-image-col {
        order: -1;
        flex-direction: row;
        align-items: flex-start;
        flex-wrap: wrap;
    }
    .avatar-card { width: auto; min-width: 200px; flex: 1; }
    .upload-form  { flex: 1; min-width: 200px; }
    .password-form__grid { grid-template-columns: 1fr; }
}

@media (max-width: 640px) {
    .topnav  { padding: 0 20px; }
    .page-header { padding: 36px 20px 20px; }
    .main-content { padding: 0 20px 60px; }
    .card { padding: 24px 20px; }
    .page-header__title { font-size: 28px; }
    .password-footer { flex-direction: column; align-items: flex-start; }
    .topnav__greeting { display: none; }
}