/* Reset */
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #f4f7fb;
}

/* Header */
h2 {
    text-align: center;
    padding: 20px;
    color: #1e3a8a;
}

/* Table Container */
table {
    width: 80%;
    margin: 20px auto;
    border-collapse: collapse;
    background-color: white;
    box-shadow: 0px 4px 10px rgba(0,0,0,0.1);
}

/* Table Header */
th {
    background-color: #1e3a8a;
    color: white;
    padding: 12px;
}

/* Table Rows */
td {
    text-align: center;
    padding: 10px;
    border-bottom: 1px solid #ddd;
}

/* Hover effect */
tr:hover {
    background-color: #f1f5f9;
}

/* Debit / Credit colors */
td.debit {
    color: red;
    font-weight: bold;
}

td.credit {
    color: green;
    font-weight: bold;
}

/* Button / Link */
a {
    display: block;
    width: 200px;
    margin: 20px auto;
    text-align: center;
    padding: 10px;
    background-color: #1e3a8a;
    color: white;
    text-decoration: none;
    border-radius: 5px;
}

a:hover {
    background-color: #2563eb;
}

/* ===== FILTER + ACTION BAR ===== */

/* ===== TOP ACTION BAR ===== */

.top-actions {
    width: 80%;
    margin: 20px auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

/* Filter form */
.filter-form {
    display: flex;
    align-items: center;
    gap: 10px;
}

/* Download form */
.download-form {
    display: flex;
    align-items: center;
}

/* Dropdown */
.filter-form select {
    padding: 6px 10px;
    border-radius: 5px;
    border: 1px solid #ccc;
}

/* Buttons */
.filter-form input[type="submit"] {
    background-color: #1e3a8a;
    color: white;
}

.filter-form input[type="submit"]:hover {
    background-color: #2563eb;
}

.download-form input[type="submit"] {
    background-color: #059669;
    color: white;
}

.download-form input[type="submit"]:hover {
    background-color: #10b981;
}