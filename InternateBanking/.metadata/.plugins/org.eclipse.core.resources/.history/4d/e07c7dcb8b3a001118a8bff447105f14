/* ===== BODY ===== */
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #f4f7fb;
}

/* ===== NAVBAR ===== */
.navbar {
    position: fixed;
    top: 0;
    width: 100%;
    background-color: #1e3a8a;
    color: white;
    display: flex;
    justify-content: space-between;
    padding: 12px 30px;
    align-items: center;
    z-index: 1000;
}

.logo {
    font-size: 20px;
    font-weight: bold;
}

.navbar-center a {
    color: white;
    text-decoration: none;
    margin: 0 12px;
    font-weight: 500;
}

.navbar-center a:hover {
    text-decoration: underline;
}

.navbar-right {
    display: flex;
    align-items: center;
    gap: 10px;
}

.logout-btn {
    background-color: #2563eb;
    padding: 6px 12px;
    border-radius: 5px;
    color: white;
}

/* ===== HERO SECTION ===== */
.hero {
    margin-top: 100px;
    text-align: center;
    padding: 60px 20px;
}

.hero h1 {
    color: #1e3a8a;
    font-size: 36px;
    margin-bottom: 10px;
}

.hero p {
    color: gray;
    margin-bottom: 30px;
}

/* BUTTONS */
.hero-buttons a {
    display: inline-block;
    margin: 10px;
    padding: 12px 22px;
    background-color: #1e3a8a;
    color: white;
    text-decoration: none;
    border-radius: 6px;
    transition: 0.3s;
}

.hero-buttons a:hover {
    background-color: #2563eb;
}

/* ===== INFO CARDS ===== */
.info-section {
    display: flex;
    justify-content: center;
    gap: 25px;
    padding: 40px;
    flex-wrap: wrap;
}

.info-card {
    background: white;
    padding: 25px;
    width: 260px;
    text-align: center;
    border-radius: 12px;
    box-shadow: 0px 4px 12px rgba(0,0,0,0.1);
    transition: 0.3s;
}

.info-card:hover {
    transform: translateY(-5px);
}

.info-card h3 {
    color: #1e3a8a;
}

/* ===== CONTACT ===== */
.contact {
    text-align: center;
    padding: 40px;
}

.contact h2 {
    color: #1e3a8a;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
    .info-section {
        flex-direction: column;
        align-items: center;
    }
}



/* PROFILE ICON */
.profile-container {
    position: relative;
    cursor: pointer;
}

.profile-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid white;
}

/* Default avatar */
.default-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #2563eb;
    color: white;
    font-weight: bold;
}

/* DROPDOWN */
.dropdown {
    position: absolute;
    right: 0;
    top: 55px;
    background: white;
    min-width: 160px;
    border-radius: 8px;
    box-shadow: 0px 4px 12px rgba(0,0,0,0.15);
    display: none;
    padding: 10px;
    z-index: 1000;
}

.dropdown p {
    margin: 0 0 8px;
    font-size: 14px;
    color: #1e3a8a;
}

.dropdown a {
    display: block;
    text-decoration: none;
    color: #333;
    padding: 6px 0;
}

.dropdown a:hover {
    color: #1e3a8a;
}

/* SHOW DROPDOWN */
.profile-container:hover .dropdown {
    display: block;
}